{
  "name": "mitra-backend",
  "version": "5.0.0",
  "description": "MITRA Government School AR Platform — Hardened backend for Cloud Run + Cloud SQL + Firebase Hosting",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
