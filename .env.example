# ─────────────────────────────────────────────────────────────────────────────
# MITRA Backend — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development, OR set these as Secret Manager
# entries / Cloud Run env vars in production (see WALKTHROUGH.html).
#
# DO NOT commit your real .env file. It is already gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info                       # trace | debug | info | warn | error

# ── App identity / URLs ──────────────────────────────────────────────────────
APP_BASE_URL=https://YOUR_FIREBASE_PROJECT.web.app      # Your public dashboard URL
ALLOWED_ORIGINS=https://YOUR_FIREBASE_PROJECT.web.app   # Comma-separated CORS allow-list

# ── JWT secrets (REQUIRED) ───────────────────────────────────────────────────
# Each MUST be ≥32 random bytes (e.g. `openssl rand -base64 48`).
# These MUST be different from each other. The server will refuse to boot
# with placeholder values.
JWT_SECRET=rXbUHnhaQiagDaPBFZbDA2qmcU633cx3VxwFJyFT6KC2iKVxirMXfNTDm7CPCNwH
JWT_REFRESH_SECRET=kEeCS78VvIxIpeYmTjRo9X5TLFXWGFC7oDCzvTNcFlxFPrkKCQ0vYLH6PanO9X0G
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Database (Cloud SQL — pick ONE of the three modes) ───────────────────────
# Mode A: Cloud Run + Cloud SQL Connector (recommended for production)
CLOUD_SQL_INSTANCE=your-project:asia-south1:mitra-db
DB_NAME=mitra
DB_USER=mitra_app
DB_PASSWORD=SET_VIA_SECRET_MANAGER

# Mode B: Single DATABASE_URL (e.g. local Postgres)
# DATABASE_URL=postgresql://mitra:secret@localhost:5432/mitra

# Mode C: Individual DB_* vars (TCP, e.g. via Cloud SQL Auth Proxy on 127.0.0.1)
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Pool sizing
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_IDLE_TIMEOUT_MS=30000

# ── Storage (Cloud Storage in production, local for dev) ─────────────────────
STORAGE_BUCKET=your-bucket-name      # leave blank for local-disk dev mode
LOCAL_UPLOAD_DIR=./uploads           # used only when STORAGE_BUCKET is blank
MAX_AD_FILE_MB=5
MAX_UNITY_FILE_MB=500

# ── Email (password reset, optional) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="MITRA <no-reply@mitra.gov.in>"

# ── Initial admin seed (used ONLY by `npm run seed`, never at runtime) ───────
SEED_ADMIN_EMAIL=admin@yourdomain.gov.in
SEED_ADMIN_NAME=Master Admin
# SEED_ADMIN_PASSWORD=set-this-on-the-CLI-just-once-do-not-store-here

# ── Behavior flags ───────────────────────────────────────────────────────────
ALLOW_INLINE_SCRIPTS=true            # Staging only — set 'false' for production CSP
RATE_LIMIT_AUTH_WINDOW_MS=900000     # 15 min
RATE_LIMIT_AUTH_MAX=5                # Max failed logins in window before lockout
TRUST_PROXY=true                     # Cloud Run sits behind a proxy

# ── GCP-only (auto-set by Cloud Run, override only if needed) ────────────────
# GCP_PROJECT_ID=
# K_SERVICE=
